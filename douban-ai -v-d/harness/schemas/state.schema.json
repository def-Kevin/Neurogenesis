{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harness-state",
  "title": "Harness State",
  "description": "Runtime state for Claude Code autonomous execution harness",
  "type": "object",
  "required": [
    "plan_id",
    "plan_version",
    "status",
    "current_phase",
    "current_task",
    "completed_tasks",
    "failed_attempts",
    "max_retries_per_task",
    "iteration_count",
    "checkpoint_reached",
    "next_checkpoint"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "harness-state"
    },
    "plan_id": {
      "type": "string"
    },
    "plan_version": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "running",
        "checkpoint",
        "stuck",
        "complete"
      ]
    },
    "current_phase": {
      "type": "string"
    },
    "current_task": {
      "type": "string"
    },
    "completed_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_attempts": {
      "type": "integer",
      "minimum": 0
    },
    "max_retries_per_task": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "last_iteration_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "iteration_count": {
      "type": "integer",
      "minimum": 0
    },
    "context_compression_level": {
      "type": "string",
      "enum": [
        "normal",
        "high"
      ]
    },
    "checkpoint_reached": {
      "type": "boolean"
    },
    "next_checkpoint": {
      "type": "string"
    },
    "user_stop_requested": {
      "type": "boolean",
      "default": false
    }
  }
}
