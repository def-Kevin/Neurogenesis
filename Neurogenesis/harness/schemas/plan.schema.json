{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harness-plan",
  "title": "Harness Plan",
  "description": "Plan file format for Claude Code autonomous execution",
  "type": "object",
  "required": [
    "plan_id",
    "version",
    "phases"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_phases": {
      "type": "integer"
    },
    "total_tasks": {
      "type": "integer"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase_id",
          "name",
          "tasks"
        ],
        "properties": {
          "phase_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "task_id",
                "description",
                "acceptance_criteria"
              ],
              "properties": {
                "task_id": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "acceptance_criteria": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "estimated_complexity": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "verification_command": {
                  "type": "string"
                }
              }
            }
          },
          "checkpoint": {
            "type": "object",
            "required": [
              "checkpoint_id",
              "type"
            ],
            "properties": {
              "checkpoint_id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "phase-gate",
                  "milestone-gate",
                  "review-gate",
                  "risk-gate"
                ]
              },
              "requires_user_approval": {
                "type": "boolean",
                "default": true
              },
              "deliverables": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
